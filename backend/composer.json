{
  "name": "ecommerce/backend",
  "description": "E-commerce REST API",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "firebase/php-jwt": "^6.10",
    "phpmailer/phpmailer": "^6.9",
    "stripe/stripe-php": "^13.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "audit": {
      "abandoned": "ignore"
    }
  }
}
